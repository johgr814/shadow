{
  "$schema": "https://json.schemastore.org/package",
  "name": "shadow-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "pnpm --filter @shadow/backend start",
    "dev": "pnpm --filter @shadow/frontend dev",
    "build": "pnpm --filter @shadow/frontend build",
    "preview": "pnpm --filter @shadow/frontend preview",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check . --write --unsafe",
    "format": "biome format . --write",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test:e2e": "pnpm --filter @shadow/backend test:e2e",
    "package": "pnpm build",
    "deps:update": "pnpm update --recursive --latest",
    "ci": "pnpm run lint && pnpm run knip && pnpm run typecheck && pnpm run test:e2e"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "knip": "^5.63.1",
    "typescript": "^5.9.3"
  }
}
