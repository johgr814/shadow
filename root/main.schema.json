{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shadow.thruput.se/schemas/main.schema.json",
  "title": "Shadow - Main schema",
  "$defs": {
    "Name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "A human-readable display name"
    },
    "Concept": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "A branded string identifying a concept in the resource tree"
    },
    "Slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 50,
      "description": "A string suitable for use as a URL"
    }
  }
}

